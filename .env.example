# SID-API-CONFIG: Copy to .env and fill in your values. Never commit .env.
OPENROUTER_API_KEY=your-openrouter-api-key-here

# IID-AUTH-BASIC: Secret used to sign Chainlit session JWT tokens.
# Generate with:  chainlit create-secret
# Also set as a Railway environment variable for production.
CHAINLIT_AUTH_SECRET=

# IID-SHEETS-LOG: Service account JSON for Google Sheets logging (optional).
# Paste the full contents of your service account key JSON as a single-line string.
# Also set sheets_log_id in config.yaml to the target Sheet ID.
GOOGLE_SERVICE_ACCOUNT_JSON=
